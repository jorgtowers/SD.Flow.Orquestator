{
  "Description": "Archivar documentos antiguos de más de 30 días",
  "ActionName": "MoveFiles",
  "Parameters": {
    "SourceDirectory": "C:/Entrada/Facturas",
    "SearchPattern": "*.txt, *.xlsx",
    "DestinationDirectory": "C:/Almacen/Historico_Mensual",
    "ExcludedItems": "Manuales, Importante.txt",
    "Recursive": "true",
    "DateFilter": ">30d",
    "DateProperty": "Modified",
    "SimulationMode": "false"
  }
}