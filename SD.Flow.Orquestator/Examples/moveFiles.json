{
  "Description": "Mover archivos con criterios extendidos de tiempo y exclusión",
  "ActionName": "MoveFiles",
  "Parameters": {
    "SourceDirectory": "C:/Entrada/Facturas",
    "SearchPattern": "*.xlsx, *.docx, *.txt",
    "DestinationDirectory": "C:/Almacen/Procesados_2026",
    "ExcludedItems": "Seguro Social, backup.txt, Nominas",
    "Recursive": "true",
    "DateFilter": "2026-01-01 TO TODAY",
    "DateProperty": "Modified",
    "SimulationMode": "false"
  }
}


{
  "Description": "SIMULACIÓN: Previsualizar movimiento de archivos del año 2026",
  "ActionName": "MoveFiles",
  "Parameters": {
    "SourceDirectory": "C:/Entrada/Facturas",
    "SearchPattern": "*.*",
    "DestinationDirectory": "C:/Almacen/Procesados_2026",
    "ExcludedItems": "backup, temp",
    "Recursive": "true",
    "DateFilter": "2026-01-01 TO TODAY",
    "DateProperty": "Modified",
    "SimulationMode": "true"
  }
}

{
  "Description": "Mover facturas creadas en la primera quincena de enero",
  "ActionName": "MoveFiles",
  "Parameters": {
    "SourceDirectory": "C:/Entrada/Facturas",
    "SearchPattern": "*.docx, *.pdf",
    "DestinationDirectory": "C:/Auditoria/Enero_2026",
    "ExcludedItems": "Borradores, Test",
    "Recursive": "true",
    "DateFilter": "2026-01-01 TO 2026-01-15",
