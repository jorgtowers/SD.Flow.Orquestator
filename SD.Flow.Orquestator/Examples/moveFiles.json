{
  "Description": "Lote: heredar estructura de carpetas del origen (fol1, fol2\\int1 → mismo árbol en destino)",
  "ActionName": "MoveFiles",
  "Parameters": {
    "SourceDirectory": "C:/Entrada",
    "DestinationDirectory": "C:/Almacen/Procesados",
    "SearchPattern": "*.xlsx, *.pdf",
    "DestinationLayout": "PreserveStructure",
    "Recursive": "true",
    "ExcludedItems": "backup, temp",
    "DateFilter": "2026-01-01 TO TODAY",
    "DateProperty": "Modified",
    "Overwrite": "true",
    "SimulationMode": "false"
  }
}

{
  "Description": "Lote: todo junto en una carpeta (sin subcarpetas, solo nombre de archivo)",
  "ActionName": "MoveFiles",
  "Parameters": {
    "SourceDirectory": "C:/Entrada",
    "DestinationDirectory": "C:/Almacen/TodoJunto",
    "SearchPattern": "*.txt, *.docx",
    "DestinationLayout": "Flat",
    "Recursive": "true",
    "Overwrite": "true",
    "SimulationMode": "false"
  }
}

{
  "Description": "SIMULACIÓN: previsualizar movimiento en modo Flat",
  "ActionName": "MoveFiles",
  "Parameters": {
    "SourceDirectory": "C:/Entrada/Facturas",
    "DestinationDirectory": "C:/Almacen/TodoJunto",
    "SearchPattern": "*.*",
    "DestinationLayout": "Flat",
    "Recursive": "true",
    "SimulationMode": "true"
  }
}
